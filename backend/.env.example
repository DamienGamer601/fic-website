# --- Discord OAuth2 (Discord Developer Portal > ton appli > OAuth2) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback

# --- Discord Bot (pour vérifier les rôles staff/chauffeur validé sur ton serveur) ---
# Crée un bot dans la même appli Discord, invite-le sur ton serveur avec la permission "View Server Members"
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# ID du rôle Discord "Staff" (autorisé à valider les chauffeurs)
DISCORD_STAFF_ROLE_ID=
# ID du rôle Discord donné automatiquement aux chauffeurs validés (optionnel, le bot pourra l'attribuer)
DISCORD_DRIVER_ROLE_ID=

# --- Validation des chauffeurs directement dans Discord (boutons) ---
# Clé publique de ton appli (Developer Portal > General Information > Public Key)
DISCORD_PUBLIC_KEY=
# Salon où poster les demandes d'accès avec les boutons Valider/Refuser
DISCORD_STAFF_CHANNEL_ID=

# --- Webhook Discord pour recevoir les candidatures de recrutement (optionnel) ---
DISCORD_RECRUIT_WEBHOOK_URL=

# --- TruckyApp (VTC Hub) ---
# Company Settings > Integrations > Claim API Company Access Token sur hub.truckyapp.com
TRUCKY_COMPANY_ID=82
TRUCKY_API_TOKEN=

# --- Divers ---
SESSION_SECRET=change-moi-en-une-longue-chaine-aleatoire
FRONTEND_URL=http://localhost:5500
PORT=3001
